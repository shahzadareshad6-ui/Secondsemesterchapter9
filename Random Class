import java.util.Random;

public class TestRandom {

    public static void main(String[] args) {

        Random random = new Random(1000);

        System.out.println("First 50 random integers:");

        for (int i = 1; i <= 50; i++) {
            System.out.print(random.nextInt(100) + " ");

            // چاپ 10 عدد در هر خط
            if (i % 10 == 0) {
                System.out.println();
            }
        }
    }
}
